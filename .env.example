# Optional — free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional — Tiingo EOD prices / meta / news (https://www.tiingo.com/account/api/token)
# Prefer this over Yahoo for price history in production. Never commit a real key.
TIINGO_API_KEY=

# Deploy-time OHLCV provider preference: tiingo | yfinance (Railway: PRICE_PRIMARY)
PRICE_PRIMARY=tiingo

# Optional — Financial Modeling Prep earnings / EPS (https://site.financialmodelingprep.com/)
# Free tier ~250 calls/day. Never commit a real key.
FMP_API_KEY=

# Deploy-time earnings provider preference: fmp | yfinance (Railway: EARNINGS_PRIMARY)
EARNINGS_PRIMARY=fmp

# Required by SEC EDGAR fair-use policy (include contact email)
SEC_USER_AGENT=Ledgerline/0.1 (your-email@example.com)

# SQLite cache path (Docker default: /data/finance.db)
DATABASE_PATH=./data/finance.db

# Comma-separated CORS origins (same-origin SPA in Docker usually needs none extra)
# CORS_ORIGINS=http://localhost:5180,https://your-app.up.railway.app
