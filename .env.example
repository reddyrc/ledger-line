# Optional — free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Required by SEC EDGAR fair-use policy (include contact email)
SEC_USER_AGENT=Ledgerline/0.1 (your-email@example.com)

# SQLite cache path (Docker default: /data/finance.db)
DATABASE_PATH=./data/finance.db

# Comma-separated CORS origins (same-origin SPA in Docker usually needs none extra)
# CORS_ORIGINS=http://localhost:5180,https://your-app.up.railway.app
